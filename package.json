{
  "name": "ortheon",
  "version": "0.6.0",
  "description": "Declarative behavioral spec framework: browser + API steps, named outputs, explicit assertions",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ortheon": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx demo/server.ts",
    "dev": "tsx demo/server.ts & DEMO_BASE_URL=http://localhost:3737 E2E_USER_EMAIL=buyer@example.com E2E_USER_PASSWORD=password123 E2E_ADMIN_EMAIL=admin@example.com E2E_ADMIN_PASSWORD=adminpass tsx src/cli.ts serve 'examples/specs/**/*.ortheon.ts'",
    "examples": "tsx scripts/run-examples.ts",
    "serve": "tsx src/cli.ts serve 'examples/specs/**/*.ortheon.ts'",
    "server-tests": "tsx scripts/run-server-tests.ts",
    "cli-remote-tests": "tsx scripts/run-cli-remote-tests.ts",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "prepublishOnly": "npm test && npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "express": "^4.21.1",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.0",
    "husky": "^9.1.7",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
